# ======================================================================
# CONFIGURACIÓN DEL LABORATORIO - TRADUCTOR FAMILIAR ESPAÑOL-RUMANO
# ======================================================================
#
# Este archivo es una plantilla pública de configuración.
# No debe contener claves reales, tokens, credenciales privadas ni rutas
# sensibles del sistema.
#
# Para usar valores reales en local, crea un archivo .env basado en esta
# plantilla. El archivo .env no debe subirse a Git.
# ======================================================================


# ======================================================================
# 1. BARRERAS DE SEGURIDAD (CONFIANZA CERO)
# ======================================================================
#
# MODO_SIMULACION=true obliga al laboratorio a trabajar con adaptadores
# fake o rutas seguras cuando aplique.
#
# PERMITIR_APIS_REALES=false impide llamadas reales a proveedores externos,
# aunque existan claves configuradas en .env.
#
# Para permitir una llamada real deben cumplirse ambas condiciones:
# MODO_SIMULACION=false
# PERMITIR_APIS_REALES=true
# ======================================================================

MODO_SIMULACION=true
PERMITIR_APIS_REALES=false


# ======================================================================
# 2. CONFIGURACIÓN DE IDIOMAS
# ======================================================================
#
# es = español
# ro = rumano
# en = inglés como ruta candidata o posible idioma puente
# ======================================================================

IDIOMAS_HABILITADOS=es,ro,en
IDIOMA_PRINCIPAL_USUARIO=es
IDIOMA_FAMILIA_PRINCIPAL=ro
IDIOMA_PUENTE=en
USAR_IDIOMA_PUENTE=false
PERMITIR_PRUEBAS_CON_INGLES=true


# ======================================================================
# 3. CONFIGURACIÓN DE MOTORES
# ======================================================================
#
# AUTO:
#   El sistema decide el camino técnico según idioma, proveedor y fase.
#
# Translate:
#   Ruta candidata para traducción realtime cuando el proveedor soporte
#   el idioma de salida.
#
# Whisper Pipeline:
#   Ruta modular: transcripción -> traducción -> voz.
#
# Combined:
#   Modo experimental para validación cruzada.
# ======================================================================

MODO_MOTOR=AUTO
PERMITIR_TRANSLATE_REALTIME=false
PERMITIR_WHISPER_REALTIME=false
PERMITIR_PIPELINE_MODULAR=true
PERMITIR_MODO_COMBINADO=false


# ======================================================================
# 4. LÍMITES DE USO Y COSTE
# ======================================================================
#
# Estos límites reducen el riesgo de gasto accidental durante pruebas.
# ======================================================================

MAX_LLAMADAS_POR_EJECUCION=10
MAX_CARACTERES_POR_FRASE=300
MAX_FRASES_POR_PRUEBA=5

MAX_CARACTERES_DIARIOS_TRADUCCION=5000
MAX_MINUTOS_TRANSLATE_DIA=10
MAX_MINUTOS_WHISPER_DIA=10
MAX_MINUTOS_MODO_COMBINADO_DIA=5
MAX_LLAMADAS_PIPELINE_DIA=50

DETENER_SI_SUPERA_LIMITE=true


# ======================================================================
# 5. TIMEOUTS Y REINTENTOS
# ======================================================================
#
# Ningún proveedor externo debe esperar indefinidamente.
# Ningún adaptador debe reintentar sin límite.
# ======================================================================

REINTENTOS_MAXIMOS=2
TIMEOUT_TRADUCCION_SEGUNDOS=3
TIMEOUT_VOZ_SEGUNDOS=5
TIMEOUT_TRANSCRIPCION_SEGUNDOS=5


# ======================================================================
# 6. CACHÉ Y RUTAS LOCALES
# ======================================================================
#
# La caché ayuda a evitar llamadas repetidas, reducir coste y mejorar
# tiempos de respuesta.
# ======================================================================

USAR_CACHE=true
RUTA_CACHE_FRASES=resultados/cache_frases.json
RUTA_RESULTADOS=resultados
RUTA_AUDIOS_SALIDA=audios_salida


# ======================================================================
# 7. PROVEEDOR: DEEPL (FASE 2)
# ======================================================================
#
# La clave real debe ir solo en .env.
# Nunca colocar claves reales en .env.example.
# ======================================================================

DEEPL_API_KEY=
DEEPL_USAR_PRO=false


# ======================================================================
# 8. PROVEEDORES DE VOZ (FASE 3 - PENDIENTE)
# ======================================================================
#
# Estas variables preparan Fase 3 sin activar voz real por defecto.
# ======================================================================

PERMITIR_VOZ_REAL=false
PROVEEDOR_VOZ=fake

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_RO=
MAX_CARACTERES_ELEVENLABS_DIA=1000

PERMITIR_GTTS=false


# ======================================================================
# 9. PROVEEDORES DE TRANSCRIPCIÓN (FASE FUTURA)
# ======================================================================
#
# Estas variables quedan preparadas para pruebas futuras de audio -> texto.
# No deben activarse todavía si la fase actual no lo permite.
# ======================================================================

PERMITIR_TRANSCRIPCION_REAL=false
PROVEEDOR_TRANSCRIPCION=fake

OPENAI_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=